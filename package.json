{
  "name": "swimhub-scanner",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@swimhub-scanner/web",
    "dev:mobile": "pnpm --filter @swimhub-scanner/mobile start",
    "ios": "pnpm --filter @swimhub-scanner/mobile ios",
    "android": "pnpm --filter @swimhub-scanner/mobile android",
    "build": "turbo build --filter=!@swimhub-scanner/mobile",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "test": "turbo test",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "deploy": "turbo build --filter=!@swimhub-scanner/mobile && pnpm --filter @swimhub-scanner/web run deploy"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"]
  },
  "devDependencies": {
    "turbo": "^2.6.0",
    "prettier": "^3.4.0"
  }
}
