{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "jsx": "react-native",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".expo", "dist", "__tests__"]
}
