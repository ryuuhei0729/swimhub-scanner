{
  "name": "@swimhub-scanner/mobile",
  "version": "1.0.0",
  "private": true,
  "description": "タイム記録表スキャナー - モバイルアプリケーション",
  "main": "expo-router/entry",
  "scripts": {
    "start": "pnpm exec dotenvx run -f .env.local -- expo start",
    "start:clear": "pnpm exec dotenvx run -f .env.local -- expo start --clear",
    "android": "pnpm exec dotenvx run -f .env.local -- expo start --android",
    "android:clear": "pnpm exec dotenvx run -f .env.local -- expo start --android --clear",
    "ios": "pnpm exec dotenvx run -f .env.local -- expo start --ios --dev-client",
    "ios:run": "pnpm exec dotenvx run -f .env.local -- expo run:ios",
    "ios:clear": "pnpm exec dotenvx run -f .env.local -- expo start --ios --dev-client --clear",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "pnpm exec expo clean"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "expo-router": "~6.0.23",
    "@supabase/supabase-js": "^2.80.0",
    "@swimhub-scanner/i18n": "workspace:*",
    "@swimhub-scanner/shared": "workspace:*",
    "i18next": "^24.0.0",
    "react-i18next": "^15.0.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "^6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.5",
    "react-native": "^0.81.5",
    "react-native-google-mobile-ads": "^16.0.3",
    "react-native-purchases": "^9.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-view-shot": "^4.0.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/react": "^19.1.17",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.3",
    "globals": "^17.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.0"
  }
}
