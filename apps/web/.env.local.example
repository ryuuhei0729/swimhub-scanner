# Copy to .env.local and fill in values
# Use the same Supabase project as SwimHub (swim-hub.app)

# Supabase (SwimHub と同じプロジェクト)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI
GEMINI_API_KEY=

# Mock mode (development without external services):
#   Set SUPABASE_MOCK_MODE=true and GEMINI_API_KEY=mock
# SUPABASE_MOCK_MODE=true
